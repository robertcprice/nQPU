/// Noise model configuration for quantum devices
#[cfg(feature = "python")]
#[pyclass(name = "NoiseModel")]
#[derive(Debug, Clone)]
pub struct PyNoiseModel {
    inner: NoiseModel,
}

#[cfg(feature = "python")]
#[pymethods]
impl PyNoiseModel {
    /// Create a noise model with custom parameters
    #[new]
    fn new(
        depolarizing_prob: f64,
        amplitude_damping_prob: f64,
        readout_error: f64,
    ) -> PyResult<Self> {
        if depolarizing_prob < 0.0 || depolarizing_prob > 1.0 {
            return Err(PyValueError::new_err(
                "depolarizing_prob must be between 0 and 1",
            ));
        }

        Ok(PyNoiseModel {
            inner: NoiseModel {
                depolarizing_prob,
                amplitude_damping_prob,
                phase_damping_prob: amplitude_damping_prob * 0.5,
                readout_error: (readout_error, readout_error),
                coherent_errors: std::collections::HashMap::new(),
                crosstalk_prob: 0.0001,
            },
        })
    }

    /// Get depolarizing probability
    #[getter]
    fn depolarizing_prob(&self) -> f64 {
        self.inner.depolarizing_prob
    }

    /// Get amplitude damping probability
    #[getter]
    fn amplitude_damping_prob(&self) -> f64 {
        self.inner.amplitude_damping_prob
    }

    /// Create noise model for IBM Quantum devices
    #[staticmethod]
    fn ibm_nqubit() -> Self {
        PyNoiseModel {
            inner: NoiseModel::ibm_nqubit(),
        }
    }

    /// Create noise model for Google Sycamore
    #[staticmethod]
    fn google_sycamore() -> Self {
        PyNoiseModel {
            inner: NoiseModel::google_sycamore(),
        }
    }

    /// Create noise model for Rigetti Aspen
    #[staticmethod]
    fn rigetti_aspen() -> Self {
        PyNoiseModel {
            inner: NoiseModel::rigetti_aspen(),
        }
    }

    fn __repr__(&self) -> String {
        format!(
            "<NoiseModel depol={:.4}, amp_damp={:.4}>",
            self.inner.depolarizing_prob, self.inner.amplitude_damping_prob
        )
    }
}

/// Simulate noisy circuit by adding readout errors
#[cfg(feature = "python")]
#[pyfunction]
#[pyo3(signature = (num_qubits, readout_error, shots=1000))]
fn simulate_noisy_circuit(
    num_qubits: usize,
    readout_error: f64,
    shots: usize,
) -> PyResult<std::collections::HashMap<String, usize>> {
    if num_qubits > 12 {
        return Err(PyValueError::new_err(
            "Maximum 12 qubits for noisy simulation",
        ));
    }
    if readout_error < 0.0 || readout_error > 1.0 {
        return Err(PyValueError::new_err(
            "readout_error must be between 0 and 1",
        ));
    }

    let mut counts: std::collections::HashMap<String, usize> = std::collections::HashMap::new();
    use rand::SeedableRng;
    let mut rng = rand::rngs::StdRng::from_entropy();

    // Run circuit with readout noise
    for _ in 0..shots {
        let mut sim = QuantumSimulator::new(num_qubits);
        sim.h(0);
        for i in 0..(num_qubits - 1) {
            sim.cnot(i, i + 1);
        }

        // Measure and apply readout error
        let ideal_result = sim.measure();

        // Apply bit flip readout error
        let mut noisy_result = 0usize;
        for bit in 0..num_qubits {
            let bit_value = (ideal_result >> bit) & 1;
            let noisy_bit = if rng.gen_range(0.0..1.0) < readout_error {
                1 - bit_value
            } else {
                bit_value
            };
            noisy_result |= (noisy_bit as usize) << bit;
        }

        let bitstring = format!("{:0width$b}", noisy_result, width = num_qubits);
        *counts.entry(bitstring).or_insert(0) += 1;
    }

    Ok(counts)
}

/// Compare ideal vs noisy circuit results
#[cfg(feature = "python")]
#[pyfunction]
#[pyo3(signature = (readout_error=0.02, shots=1000))]
fn compare_ideal_vs_noisy(readout_error: Option<f64>, shots: Option<usize>) -> PyResult<String> {
    let ro = readout_error.unwrap_or(0.02);
    let n_shots = shots.unwrap_or(1000);

    let mut ideal_counts: std::collections::HashMap<String, usize> =
        std::collections::HashMap::new();

    // Ideal Bell state - recreate for each shot since measurement collapses state
    for _ in 0..n_shots {
        let mut sim = QuantumSimulator::new(2);
        sim.h(0);
        sim.cnot(0, 1);
        let m = sim.measure();
        let bitstring = format!("{:02b}", m);
        *ideal_counts.entry(bitstring).or_insert(0) += 1;
    }

    // Noisy simulation
    let noisy_counts = simulate_noisy_circuit(2, ro, n_shots)?;

    // Calculate statistics
    let ideal_00 = *ideal_counts.get("00").unwrap_or(&0) as f64;
    let ideal_11 = *ideal_counts.get("11").unwrap_or(&0) as f64;
    let noisy_00 = *noisy_counts.get("00").unwrap_or(&0) as f64;
    let noisy_11 = *noisy_counts.get("11").unwrap_or(&0) as f64;

    // Fidelity estimate
    let overlap = (ideal_00.min(noisy_00) + ideal_11.min(noisy_11))
        / (ideal_00.max(noisy_00) + ideal_11.max(noisy_11) + 1.0);

    Ok(format!(
        "Bell State Comparison ({} shots, readout_error={}):\n\
         Ideal:   |00⟩={} ({:.1}%), |11⟩={} ({:.1}%)\n\
         Noisy:   |00⟩={} ({:.1}%), |11⟩={} ({:.1}%)\n\
         Fidelity: {:.4} (measurement overlap)",
        n_shots,
        ro,
        ideal_00 as i64,
        ideal_00 / n_shots as f64 * 100.0,
        ideal_11 as i64,
        ideal_11 / n_shots as f64 * 100.0,
        noisy_00 as i64,
        noisy_00 / n_shots as f64 * 100.0,
        noisy_11 as i64,
        noisy_11 / n_shots as f64 * 100.0,
        overlap
    ))
}

/// Python wrapper for MPSSimulator (Matrix Product State)
///
/// MPS representation enables efficient simulation of larger quantum systems
/// by compressing the state tensor based on entanglement structure.
#[cfg(feature = "python")]
#[pyclass(name = "MPSSimulator")]
pub struct PyMPSSimulator {
    inner: MPSSimulator,
}

#[cfg(feature = "python")]
#[pymethods]
impl PyMPSSimulator {
    /// Create a new MPS simulator
    ///
    /// Args:
    ///     num_qubits: Number of qubits to simulate
    ///     max_bond_dim: Maximum bond dimension for compression (None for unlimited)
    #[new]
    #[pyo3(signature = (num_qubits, max_bond_dim=None))]
    fn new(num_qubits: usize, max_bond_dim: Option<usize>) -> PyResult<Self> {
        if num_qubits > 100000 {
            // No hard limit - actual limit depends on memory and bond dimension
            // 24GB RAM can theoretically handle ~1M qubits at bond_dim=2
        }
        Ok(PyMPSSimulator {
            inner: MPSSimulator::new(num_qubits, max_bond_dim),
        })
    }

    /// Get the number of qubits
    #[getter]
    fn num_qubits(&self) -> usize {
        self.inner.num_qubits()
    }

    /// Get current bond dimensions
    #[getter]
    fn bond_dimensions(&self) -> Vec<usize> {
        self.inner.bond_dimensions()
    }

    /// Get maximum current bond dimension
    #[getter]
    fn max_bond_dim(&self) -> usize {
        self.inner.max_bond_dim()
    }

    /// Apply Hadamard gate
    fn h(&mut self, qubit: usize) -> PyResult<()> {
        if qubit >= self.inner.num_qubits() {
            return Err(PyValueError::new_err("Qubit index out of bounds"));
        }
        self.inner.h(qubit);
        Ok(())
    }

    /// Apply X (NOT) gate
    fn x(&mut self, qubit: usize) -> PyResult<()> {
        if qubit >= self.inner.num_qubits() {
            return Err(PyValueError::new_err("Qubit index out of bounds"));
        }
        self.inner.x(qubit);
        Ok(())
    }

    /// Apply Y gate
    fn y(&mut self, qubit: usize) -> PyResult<()> {
        if qubit >= self.inner.num_qubits() {
            return Err(PyValueError::new_err("Qubit index out of bounds"));
        }
        self.inner.y(qubit);
        Ok(())
    }

    /// Apply Z gate
    fn z(&mut self, qubit: usize) -> PyResult<()> {
        if qubit >= self.inner.num_qubits() {
            return Err(PyValueError::new_err("Qubit index out of bounds"));
        }
        self.inner.z(qubit);
        Ok(())
    }

    /// Apply S gate (phase gate)
    fn s(&mut self, qubit: usize) -> PyResult<()> {
        if qubit >= self.inner.num_qubits() {
            return Err(PyValueError::new_err("Qubit index out of bounds"));
        }
        self.inner.s(qubit);
        Ok(())
    }

    /// Apply T gate (π/8 gate)
    fn t(&mut self, qubit: usize) -> PyResult<()> {
        if qubit >= self.inner.num_qubits() {
            return Err(PyValueError::new_err("Qubit index out of bounds"));
        }
        self.inner.t(qubit);
        Ok(())
    }

    /// Apply Rx gate (rotation around X-axis)
    fn rx(&mut self, qubit: usize, theta: f64) -> PyResult<()> {
        if qubit >= self.inner.num_qubits() {
            return Err(PyValueError::new_err("Qubit index out of bounds"));
        }
        self.inner.rx(qubit, theta);
        Ok(())
    }

    /// Apply Ry gate (rotation around Y-axis)
    fn ry(&mut self, qubit: usize, theta: f64) -> PyResult<()> {
        if qubit >= self.inner.num_qubits() {
            return Err(PyValueError::new_err("Qubit index out of bounds"));
        }
        self.inner.ry(qubit, theta);
        Ok(())
    }

    /// Apply Rz gate (rotation around Z-axis)
    fn rz(&mut self, qubit: usize, theta: f64) -> PyResult<()> {
        if qubit >= self.inner.num_qubits() {
            return Err(PyValueError::new_err("Qubit index out of bounds"));
        }
        self.inner.rz(qubit, theta);
        Ok(())
    }

    /// Apply CNOT gate
    fn cnot(&mut self, control: usize, target: usize) -> PyResult<()> {
        let n = self.inner.num_qubits();
        if control >= n || target >= n {
            return Err(PyValueError::new_err("Qubit index out of bounds"));
        }
        if control == target {
            return Err(PyValueError::new_err(
                "Control and target must be different",
            ));
        }
        self.inner.cnot(control, target);
        Ok(())
    }

    /// Swap two qubits
    fn swap(&mut self, qubit1: usize, qubit2: usize) -> PyResult<()> {
        let n = self.inner.num_qubits();
        if qubit1 >= n || qubit2 >= n {
            return Err(PyValueError::new_err("Qubit index out of bounds"));
        }
        self.inner.swap(qubit1, qubit2);
        Ok(())
    }

    /// Measure all qubits
    fn measure(&mut self) -> PyResult<usize> {
        Ok(self.inner.measure())
    }

    /// Measure a single qubit
    fn measure_qubit(&mut self, qubit: usize) -> PyResult<usize> {
        if qubit >= self.inner.num_qubits() {
            return Err(PyValueError::new_err("Qubit index out of bounds"));
        }
        Ok(self.inner.measure_qubit(qubit))
    }

    /// Get probabilities by converting to state vector
    fn probabilities(&self) -> PyResult<Vec<f64>> {
        let state_vector = self.inner.mps().to_state_vector();
        Ok(state_vector.iter().map(|amp| amp.norm_sqr()).collect())
    }

    /// Sample multiple measurements
    fn sample_bitstrings(
        &self,
        shots: usize,
    ) -> PyResult<std::collections::HashMap<String, usize>> {
        use rand::Rng;
        let mut rng = rand::thread_rng();
        let mut counts = std::collections::HashMap::new();
        let state_vector = self.inner.mps().to_state_vector();
        let n = self.inner.num_qubits();

        for _ in 0..shots {
            let mut r: f64 = rng.gen();
            let mut result = 0;
            for (i, amp) in state_vector.iter().enumerate() {
                let prob = amp.norm_sqr();
                r -= prob;
                if r <= 0.0 {
                    result = i;
                    break;
                }
            }
            let bitstring = format!("{:0width$b}", result, width = n);
            *counts.entry(bitstring).or_insert(0) += 1;
        }

        Ok(counts)
    }

    /// Get string representation
    fn __repr__(&self) -> String {
        format!(
            "<MPSSimulator n={} qubits, max_bond_dim={}>",
            self.inner.num_qubits(),
            self.inner.max_bond_dim()
        )
    }

    /// Get detailed info
    fn info(&self) -> String {
        format!(
            "MPSSimulator:\n  Qubits: {}\n  Max bond dim: {}\n  Current bond dims: {:?}",
            self.inner.num_qubits(),
            self.inner.max_bond_dim(),
            self.inner.bond_dimensions()
        )
    }
}

// ============================================================
// 2D Grid Simulator using Snake-Mapped MPS
// ============================================================

use crate::snake_mapping::{GridCoord, SnakeMapper};
use std::sync::Arc;

/// 2D grid quantum simulator using snake pattern mapping to MPS
///
/// This enables simulation of 2D quantum circuits on existing MPS infrastructure.
///
/// # Example
///
/// ```python
/// import nqpu_metal
///
/// # Create 4x4 grid
/// sim = nqpu_metal.Grid2DSimulator(4, 4, max_bond_dim=2)
///
/// # Apply H to center qubit
/// sim.h(2, 1)  # x=2, y=1
///
/// # Nearest-neighbor CNOT
/// sim.cnot(2, 1, 3, 1)  # (2,1) -> (3,1)
///
/// # Measure all qubits
/// result = sim.measure()
/// ```
#[cfg(feature = "python")]
#[pyclass(name = "Grid2DSimulator")]
pub struct PyGrid2DSimulator {
    inner: Arc<std::sync::Mutex<Grid2DSimulator>>,
    mapper: SnakeMapper,
}

#[cfg(feature = "python")]
#[pymethods]
impl PyGrid2DSimulator {
    /// Create a new 2D grid simulator
    ///
    /// # Arguments
    ///
    /// * `width` - Number of qubits in each row
    /// * `height` - Number of qubits in each column
    /// * `max_bond_dim` - Maximum bond dimension for MPS (default: 2)
    #[new]
    #[pyo3(signature = (width, height, max_bond_dim=2))]
    fn new(width: usize, height: usize, max_bond_dim: Option<usize>) -> PyResult<Self> {
        let mapper = SnakeMapper::new(width, height);
        let inner = Grid2DSimulator::new(width, height, max_bond_dim);

        Ok(Self {
            inner: Arc::new(std::sync::Mutex::new(inner)),
            mapper,
        })
    }

    /// Apply Hadamard gate to qubit at (x, y)
    #[pyo3(signature = (x, y))]
    fn h(&self, x: usize, y: usize) -> PyResult<()> {
        let mut sim = self.inner.lock().unwrap();
        let idx = self.mapper.map_2d_to_1d(x, y);
        sim.h(idx);
        Ok(())
    }

    /// Apply X (NOT) gate to qubit at (x, y)
    #[pyo3(signature = (x, y))]
    fn x(&self, x: usize, y: usize) -> PyResult<()> {
        let mut sim = self.inner.lock().unwrap();
        let idx = self.mapper.map_2d_to_1d(x, y);
        sim.x(idx);
        Ok(())
    }

    /// Apply Y gate to qubit at (x, y)
    #[pyo3(signature = (x, y))]
    fn y(&self, x: usize, y: usize) -> PyResult<()> {
        let mut sim = self.inner.lock().unwrap();
        let idx = self.mapper.map_2d_to_1d(x, y);
        sim.y(idx);
        Ok(())
    }

    /// Apply Z gate to qubit at (x, y)
    #[pyo3(signature = (x, y))]
    fn z(&self, x: usize, y: usize) -> PyResult<()> {
        let mut sim = self.inner.lock().unwrap();
        let idx = self.mapper.map_2d_to_1d(x, y);
        sim.z(idx);
        Ok(())
    }

    /// Apply CNOT gate between two 2D positions
    ///
    /// Warning: Non-nearest-neighbor gates cause bond dimension growth
    #[pyo3(signature = (x1, y1, x2, y2))]
    fn cnot(&self, x1: usize, y1: usize, x2: usize, y2: usize) -> PyResult<()> {
        let mut sim = self.inner.lock().unwrap();
        let idx1 = self.mapper.map_2d_to_1d(x1, y1);
        let idx2 = self.mapper.map_2d_to_1d(x2, y2);

        // Warn about long-range gates
        let coord1 = GridCoord::new(x1, y1);
        let coord2 = GridCoord::new(x2, y2);
        let distance = self.mapper.distance(&coord1, &coord2);
        if distance > 1 {
            eprintln!(
                "Warning: Long-range CNOT (distance={}) will increase bond dimension",
                distance
            );
        }

        sim.cnot(idx1, idx2);
        Ok(())
    }

    /// Apply RX rotation to qubit at (x, y)
    #[pyo3(signature = (x, y, theta))]
    fn rx(&self, x: usize, y: usize, theta: f64) -> PyResult<()> {
        let mut sim = self.inner.lock().unwrap();
        let idx = self.mapper.map_2d_to_1d(x, y);
        sim.rx(idx, theta);
        Ok(())
    }

    /// Apply RY rotation to qubit at (x, y)
    #[pyo3(signature = (x, y, theta))]
    fn ry(&self, x: usize, y: usize, theta: f64) -> PyResult<()> {
        let mut sim = self.inner.lock().unwrap();
        let idx = self.mapper.map_2d_to_1d(x, y);
        sim.ry(idx, theta);
        Ok(())
    }

    /// Apply RZ rotation to qubit at (x, y)
    #[pyo3(signature = (x, y, theta))]
    fn rz(&self, x: usize, y: usize, theta: f64) -> PyResult<()> {
        let mut sim = self.inner.lock().unwrap();
        let idx = self.mapper.map_2d_to_1d(x, y);
        sim.rz(idx, theta);
        Ok(())
    }

    /// Measure all qubits and return integer result
    #[pyo3(signature = ())]
    fn measure(&self) -> PyResult<u64> {
        let mut sim = self.inner.lock().unwrap();
        Ok(sim.measure())
    }

    /// Get number of qubits in grid
    fn num_qubits(&self) -> usize {
        self.mapper.size()
    }

    /// Get grid dimensions
    fn dimensions(&self) -> PyResult<(usize, usize)> {
        Ok(self.mapper.dimensions())
    }

    /// Get maximum Manhattan distance between any two qubits
    fn max_distance(&self) -> usize {
        self.mapper.max_distance()
    }

    /// Get string representation
    fn __repr__(&self) -> String {
        let (width, height) = self.mapper.dimensions();
        format!("<Grid2DSimulator width={} height={}>", width, height)
    }

    /// Get detailed info
    fn info(&self) -> String {
        let (width, height) = self.mapper.dimensions();
        format!(
            "Grid2DSimulator:\n  Width: {}\n  Height: {}\n  Total qubits: {}\n  Max bond dim: {}",
            width,
            height,
            self.mapper.size(),
            self.inner.lock().unwrap().max_bond_dim()
        )
    }
}

// ============================================================
// Internal Grid2DSimulator (wraps MPS)
// ============================================================

/// Internal 2D grid simulator using snake-mapped MPS
struct Grid2DSimulator {
    mps: MPSSimulator,
    mapper: crate::snake_mapping::SnakeMapper,
    width: usize,
    height: usize,
}

impl Grid2DSimulator {
    fn new(width: usize, height: usize, max_bond_dim: Option<usize>) -> Self {
        let total_qubits = width * height;
        let mps = MPSSimulator::new(total_qubits, max_bond_dim);
        let mapper = crate::snake_mapping::SnakeMapper::new(width, height);
        Self {
            mps,
            mapper,
            width,
            height,
        }
    }

    // Delegate all operations directly to underlying MPS methods
    fn h(&mut self, idx: usize) {
        self.mps.h(idx);
    }

    fn x(&mut self, idx: usize) {
        self.mps.x(idx);
    }

    fn y(&mut self, idx: usize) {
        self.mps.y(idx);
    }

    fn z(&mut self, idx: usize) {
        self.mps.z(idx);
    }

    fn cnot(&mut self, control: usize, target: usize) {
        self.mps.cnot(control, target);
    }

    fn rx(&mut self, idx: usize, theta: f64) {
        self.mps.rx(idx, theta);
    }

    fn ry(&mut self, idx: usize, theta: f64) {
        self.mps.ry(idx, theta);
    }

    fn rz(&mut self, idx: usize, theta: f64) {
        self.mps.rz(idx, theta);
    }

    fn measure(&mut self) -> u64 {
        self.mps.measure() as u64
    }

    fn max_bond_dim(&self) -> usize {
        self.mps.max_bond_dim()
    }

    // ============================================================
    // 2D ALGORITHM HELPERS (delegate to algorithms_2d)
    // ============================================================

    /// Apply 2D QFT using algorithms_2d
    fn qft_2d(&mut self) -> PyResult<()> {
        crate::algorithms_2d::qft_2d(&mut self.mps, self.width, self.height, &self.mapper);
        Ok(())
    }

    /// Apply inverse 2D QFT
    fn inverse_qft_2d(&mut self) -> PyResult<()> {
        crate::algorithms_2d::inverse_qft_2d(&mut self.mps, self.width, self.height, &self.mapper);
        Ok(())
    }

    /// Get entanglement entropy grid
    fn entanglement_entropy_2d(&self) -> PyResult<Vec<Vec<f64>>> {
        let grid = crate::algorithms_2d::entanglement_entropy_2d(
            &self.mps,
            self.width,
            self.height,
            &self.mapper,
        );
        // Extract just entropy values
        let result: Vec<Vec<f64>> = grid
            .iter()
            .map(|row| row.iter().map(|d| d.entropy).collect())
            .collect();
        Ok(result)
    }

    /// Sample power measurements
    fn power_sample_2d(
        &mut self,
        shots: usize,
    ) -> PyResult<std::collections::HashMap<String, usize>> {
        if shots > 100000 {
            return Err(PyValueError::new_err("Maximum 100000 shots"));
        }
        let measurement = crate::algorithms_2d::power_sample_2d(
            &mut self.mps,
            self.width,
            self.height,
            &self.mapper,
            shots,
        );
        // Convert to hashmap format
        let mut result = std::collections::HashMap::new();
        for y in 0..self.height {
            for x in 0..self.width {
                let key = format!("{},{}", x, y);
                result.insert(key, measurement.counts[y][x]);
            }
        }
        Ok(result)
    }

    /// Apply square CNOT from center
    fn square_cnot(&mut self, center_x: usize, center_y: usize) -> PyResult<()> {
        crate::algorithms_2d::square_cnot(
            &mut self.mps,
            center_x,
            center_y,
            self.width,
            self.height,
            &self.mapper,
        );
        Ok(())
    }

    /// Run Grover 2D search
    fn grover_2d(
        &mut self,
        target_x: usize,
        target_y: usize,
        iterations: Option<usize>,
    ) -> PyResult<(usize, usize)> {
        let result = crate::algorithms_2d::grover_2d(
            &mut self.mps,
            self.width,
            self.height,
            &self.mapper,
            &|x, y| x == target_x && y == target_y,
            iterations,
        );
        Ok((result.x, result.y))
    }

    /// Run 2D benchmarks
    fn benchmark_2d(
        &self,
        sizes: Vec<(usize, usize)>,
        max_bond_dim: Option<usize>,
        iterations: usize,
    ) -> PyResult<String> {
        let (widths, heights): (Vec<usize>, Vec<usize>) = sizes.into_iter().unzip();
        let results =
            crate::algorithms_2d::benchmark_suite_2d(widths, heights, max_bond_dim, iterations);

        // Format results
        let mut output = String::from("2D Quantum Algorithm Benchmarks\n");
        output.push_str(&format!("========================================\n\n"));

        for result in &results {
            output.push_str(&format!(
                "{}: {}x{} ({} qubits)\n",
                result.name, result.width, result.height, result.total_qubits
            ));
            output.push_str(&format!("  Time: {:.3} ms/iter\n", result.duration_ms));
            if let Some(fid) = result.fidelity {
                output.push_str(&format!("  Fidelity: {:.2}%\n", fid * 100.0));
            }
            output.push_str(&format!("  Max bond dim: {}\n\n", result.max_bond_dim));
        }

        Ok(output)
    }
}

// ============================================================================
// AUTOMATIC DIFFERENTIATION (ADJOINT METHOD) — for nHybrid integration
// ============================================================================

/// Adjoint-based quantum circuit for automatic differentiation.
///
/// Supports parameterized gates (Rx, Ry, Rz) and computes exact analytic
/// gradients via reverse-mode adjoint differentiation. Used by nHybrid
/// to bridge quantum gradients into PyTorch's autograd.
#[cfg(feature = "python")]
#[pyclass(name = "AdjointCircuit")]
pub struct PyAdjointCircuit {
    inner: crate::adjoint_diff::AdjointCircuit,
}

#[cfg(feature = "python")]
#[pymethods]
impl PyAdjointCircuit {
    /// Create a new adjoint circuit with the given number of qubits.
    #[new]
    fn new(num_qubits: usize) -> PyResult<Self> {
        if num_qubits > 28 {
            return Err(PyValueError::new_err(
                "Maximum 28 qubits for adjoint circuit (state vector backend)",
            ));
        }
        Ok(PyAdjointCircuit {
            inner: crate::adjoint_diff::AdjointCircuit::new(num_qubits),
        })
    }

    /// Number of qubits in this circuit.
    #[getter]
    fn num_qubits(&self) -> usize {
        self.inner.num_qubits
    }

    /// Number of operations in this circuit.
    #[getter]
    fn num_ops(&self) -> usize {
        self.inner.ops.len()
    }

    /// Add a Hadamard gate on the target qubit.
    fn h(&mut self, qubit: usize) -> PyResult<()> {
        if qubit >= self.inner.num_qubits {
            return Err(PyValueError::new_err("Qubit index out of range"));
        }
        self.inner.add_op(crate::adjoint_diff::AdjointOp::Fixed(
            crate::gates::Gate::h(qubit),
        ));
        Ok(())
    }

    /// Add a Pauli-X gate on the target qubit.
    fn x(&mut self, qubit: usize) -> PyResult<()> {
        if qubit >= self.inner.num_qubits {
            return Err(PyValueError::new_err("Qubit index out of range"));
        }
        self.inner.add_op(crate::adjoint_diff::AdjointOp::Fixed(
            crate::gates::Gate::x(qubit),
        ));
        Ok(())
    }

    /// Add a Pauli-Y gate on the target qubit.
    fn y(&mut self, qubit: usize) -> PyResult<()> {
        if qubit >= self.inner.num_qubits {
            return Err(PyValueError::new_err("Qubit index out of range"));
        }
        self.inner.add_op(crate::adjoint_diff::AdjointOp::Fixed(
            crate::gates::Gate::y(qubit),
        ));
        Ok(())
    }

    /// Add a Pauli-Z gate on the target qubit.
    fn z(&mut self, qubit: usize) -> PyResult<()> {
        if qubit >= self.inner.num_qubits {
            return Err(PyValueError::new_err("Qubit index out of range"));
        }
        self.inner.add_op(crate::adjoint_diff::AdjointOp::Fixed(
            crate::gates::Gate::z(qubit),
        ));
        Ok(())
    }

    /// Add a CNOT gate (control → target).
    fn cnot(&mut self, control: usize, target: usize) -> PyResult<()> {
        if control >= self.inner.num_qubits || target >= self.inner.num_qubits {
            return Err(PyValueError::new_err("Qubit index out of range"));
        }
        self.inner.add_op(crate::adjoint_diff::AdjointOp::Fixed(
            crate::gates::Gate::cnot(control, target),
        ));
        Ok(())
    }

    /// Add a parametric Rx(theta) gate. param_index references into the params array.
    fn rx(&mut self, qubit: usize, param_index: usize) -> PyResult<()> {
        if qubit >= self.inner.num_qubits {
            return Err(PyValueError::new_err("Qubit index out of range"));
        }
        self.inner.add_op(crate::adjoint_diff::AdjointOp::Rx {
            qubit,
            param: param_index,
        });
        Ok(())
    }

    /// Add a parametric Ry(theta) gate. param_index references into the params array.
    fn ry(&mut self, qubit: usize, param_index: usize) -> PyResult<()> {
        if qubit >= self.inner.num_qubits {
            return Err(PyValueError::new_err("Qubit index out of range"));
        }
        self.inner.add_op(crate::adjoint_diff::AdjointOp::Ry {
            qubit,
            param: param_index,
        });
        Ok(())
    }

    /// Add a parametric Rz(theta) gate. param_index references into the params array.
    fn rz(&mut self, qubit: usize, param_index: usize) -> PyResult<()> {
        if qubit >= self.inner.num_qubits {
            return Err(PyValueError::new_err("Qubit index out of range"));
        }
        self.inner.add_op(crate::adjoint_diff::AdjointOp::Rz {
            qubit,
            param: param_index,
        });
        Ok(())
    }

    /// Compute <Z_qubit> expectation value for the given parameters.
    fn expectation(&self, params: Vec<f64>, qubit: usize) -> PyResult<f64> {
        if qubit >= self.inner.num_qubits {
            return Err(PyValueError::new_err("Observable qubit out of range"));
        }
        self.inner
            .expectation(&params, crate::adjoint_diff::Observable::PauliZ(qubit))
            .map_err(|e| PyValueError::new_err(format!("Expectation failed: {}", e)))
    }

    /// Compute d<Z_qubit>/d(params) via reverse-mode adjoint differentiation.
    ///
    /// Returns a list of gradients, one per parameter.
    fn gradient(&self, params: Vec<f64>, qubit: usize) -> PyResult<Vec<f64>> {
        if qubit >= self.inner.num_qubits {
            return Err(PyValueError::new_err("Observable qubit out of range"));
        }
        self.inner
            .gradient(&params, crate::adjoint_diff::Observable::PauliZ(qubit))
            .map_err(|e| PyValueError::new_err(format!("Gradient failed: {}", e)))
    }

    fn __repr__(&self) -> String {
        format!(
            "AdjointCircuit(num_qubits={}, num_ops={})",
            self.inner.num_qubits,
            self.inner.ops.len()
        )
    }
}

// =============================================================================
// PEPS (PROJECTED ENTANGLED PAIR STATES) PYTHON BINDINGS
// =============================================================================

/// Python wrapper for PEPSimulator (2D PEPS tensor network).
///
/// Supports single-qubit gates (H, X), two-qubit gates (CNOT),
/// measurement, amplitude extraction, and entanglement entropy.
#[cfg(feature = "python")]
#[pyclass(name = "PEPSSimulator")]
pub struct PyPEPS {
    inner: crate::peps::PEPSimulator,
}

#[cfg(feature = "python")]
#[pymethods]
impl PyPEPS {
    /// Create a new PEPS simulator on a rows x cols 2D lattice.
    ///
    /// Args:
    ///     rows: Number of rows in the lattice
    ///     cols: Number of columns in the lattice
    ///     bond_dim: Maximum bond dimension for truncation
    #[new]
    fn new(rows: usize, cols: usize, bond_dim: usize) -> Self {
        Self {
            inner: crate::peps::PEPSimulator::new(cols, rows, bond_dim),
        }
    }

    /// Apply Hadamard gate to qubit at (row, col).
    fn apply_h(&mut self, row: usize, col: usize) -> PyResult<()> {
        self.inner.h(col, row);
        Ok(())
    }

    /// Apply Pauli-X gate to qubit at (row, col).
    fn apply_x(&mut self, row: usize, col: usize) -> PyResult<()> {
        self.inner.x(col, row);
        Ok(())
    }

    /// Apply CNOT gate between two adjacent lattice sites.
    ///
    /// Sites must be nearest-neighbors (Manhattan distance = 1).
    fn apply_cnot(
        &mut self,
        r1: usize,
        c1: usize,
        r2: usize,
        c2: usize,
    ) -> PyResult<()> {
        self.inner.cnot(c1, r1, c2, r2);
        Ok(())
    }

    /// Measure all qubits, collapsing the state.
    ///
    /// Returns a list of measurement outcomes (0 or 1) for each site,
    /// ordered row-major.
    fn measure(&mut self) -> PyResult<Vec<u8>> {
        let result = self.inner.measure();
        let n = self.inner.num_qubits();
        let bits: Vec<u8> = (0..n).map(|i| ((result >> i) & 1) as u8).collect();
        Ok(bits)
    }

    /// Contract the PEPS to a full state vector and return amplitudes.
    ///
    /// Only feasible for small systems (total qubits <= ~16).
    /// Returns a list of (real, imag) tuples for each basis state.
    fn amplitudes(&self) -> PyResult<Vec<(f64, f64)>> {
        let amps = self.inner.peps().contract_to_amplitudes();
        Ok(amps.iter().map(|c| (c.re, c.im)).collect())
    }

    /// Compute per-site entanglement entropy.
    ///
    /// Returns the von Neumann entropy at lattice position (row, col)
    /// by tracing over all bond indices.
    fn entanglement_entropy(&self, row: usize, col: usize) -> PyResult<f64> {
        let grid = self.inner.entanglement_entropy_2d();
        if row >= grid.len() {
            return Err(PyValueError::new_err(format!(
                "Row {} out of range (max {})",
                row,
                grid.len().saturating_sub(1)
            )));
        }
        if col >= grid[row].len() {
            return Err(PyValueError::new_err(format!(
                "Col {} out of range (max {})",
                col,
                grid[row].len().saturating_sub(1)
            )));
        }
        Ok(grid[row][col])
    }

    /// Get the total number of lattice sites (rows * cols).
    fn num_sites(&self) -> usize {
        self.inner.num_qubits()
    }

    fn __repr__(&self) -> String {
        let (w, h) = self.inner.dimensions();
        format!("<PEPSSimulator rows={} cols={}>", h, w)
    }
}

// =============================================================================
// TTN (TREE TENSOR NETWORK) PYTHON BINDINGS
// =============================================================================

/// Python wrapper for Tree Tensor Network simulator.
///
/// TTN uses a hierarchical binary tree structure to represent quantum states,
/// providing efficient simulation for systems with limited entanglement.
#[cfg(feature = "python")]
#[pyclass(name = "TTNSimulator")]
pub struct PyTTN {
    inner: crate::tree_tensor_network::TTN,
}

#[cfg(feature = "python")]
#[pymethods]
impl PyTTN {
    /// Create a new TTN simulator in the |0...0> state.
    ///
    /// Args:
    ///     num_qubits: Number of physical qubits
    ///     bond_dim: Maximum bond dimension (controls entanglement capacity)
    #[new]
    fn new(num_qubits: usize, bond_dim: usize) -> Self {
        let config = crate::tree_tensor_network::TTNConfig::new(num_qubits, bond_dim);
        Self {
            inner: crate::tree_tensor_network::TTN::new(config),
        }
    }

    /// Apply Hadamard gate.
    fn apply_h(&mut self, qubit: usize) {
        self.inner.apply_h(qubit);
    }

    /// Apply Pauli-X gate.
    fn apply_x(&mut self, qubit: usize) {
        self.inner.apply_x(qubit);
    }

    /// Apply Pauli-Y gate.
    fn apply_y(&mut self, qubit: usize) {
        self.inner.apply_y(qubit);
    }

    /// Apply Pauli-Z gate.
    fn apply_z(&mut self, qubit: usize) {
        self.inner.apply_z(qubit);
    }

    /// Apply S gate (phase gate, pi/2 rotation).
    fn apply_s(&mut self, qubit: usize) {
        self.inner.apply_s(qubit);
    }

    /// Apply RX rotation gate.
    fn apply_rx(&mut self, qubit: usize, angle: f64) {
        self.inner.apply_rx(qubit, angle);
    }

    /// Apply RY rotation gate.
    fn apply_ry(&mut self, qubit: usize, angle: f64) {
        self.inner.apply_ry(qubit, angle);
    }

    /// Apply RZ rotation gate.
    fn apply_rz(&mut self, qubit: usize, angle: f64) {
        self.inner.apply_rz(qubit, angle);
    }

    /// Apply CNOT gate (control -> target).
    fn apply_cnot(&mut self, control: usize, target: usize) {
        self.inner.apply_cnot(control, target);
    }

    /// Get the full statevector as a list of (real, imag) pairs.
    ///
    /// Only feasible for small systems (<= ~20 qubits).
    fn statevector(&self) -> Vec<(f64, f64)> {
        let sv = self.inner.to_statevector_complex();
        sv.iter().map(|c| (c[0], c[1])).collect()
    }

    /// Sample measurement outcomes.
    ///
    /// Args:
    ///     shots: Number of measurement shots
    ///
    /// Returns a list of bitstring results, each as a list of booleans.
    fn sample(&self, shots: usize) -> Vec<Vec<bool>> {
        let sv = self.inner.to_statevector_complex();
        let n = self.inner.n_qubits();
        let probs: Vec<f64> = sv.iter().map(|c| c[0] * c[0] + c[1] * c[1]).collect();
        let total: f64 = probs.iter().sum();

        let mut rng = rand::thread_rng();
        let mut results = Vec::with_capacity(shots);
        for _ in 0..shots {
            let r: f64 = rng.gen::<f64>() * total;
            let mut cumsum = 0.0;
            let mut outcome = 0usize;
            for (i, &p) in probs.iter().enumerate() {
                cumsum += p;
                if cumsum >= r {
                    outcome = i;
                    break;
                }
            }
            let bits: Vec<bool> = (0..n).map(|b| (outcome >> b) & 1 == 1).collect();
            results.push(bits);
        }
        results
    }

    /// Compute bipartite entanglement entropy for a single qubit partition.
    ///
    /// Computes S(A) where A = {qubit} and B = everything else.
    fn entanglement_entropy(&self, qubit: usize) -> f64 {
        self.inner.entanglement_entropy(&[qubit])
    }

    /// Get the number of physical qubits.
    fn num_qubits(&self) -> usize {
        self.inner.n_qubits()
    }

    fn __repr__(&self) -> String {
        format!(
            "<TTNSimulator num_qubits={}>",
            self.inner.n_qubits()
        )
    }
}

// =============================================================================
// CIRCUIT OPTIMIZER PYTHON BINDINGS
// =============================================================================

/// Gate description for passing circuits between Python and the optimizer.
#[cfg(feature = "python")]
#[pyclass(name = "GateDesc")]
#[derive(Clone)]
pub struct PyGateDesc {
    #[pyo3(get, set)]
    pub gate_type: String,
    #[pyo3(get, set)]
    pub targets: Vec<usize>,
    #[pyo3(get, set)]
    pub controls: Vec<usize>,
    #[pyo3(get, set)]
    pub params: Option<Vec<f64>>,
}

#[cfg(feature = "python")]
#[pymethods]
impl PyGateDesc {
    /// Create a new gate description.
    ///
    /// Args:
    ///     gate_type: Gate name ("h", "x", "y", "z", "s", "t", "rx", "ry", "rz", "cnot", "cz", "swap")
    ///     targets: Target qubit indices
    ///     controls: Control qubit indices (empty for single-qubit gates)
    ///     params: Optional parameters (angles for rotation gates)
    #[new]
    #[pyo3(signature = (gate_type, targets, controls=vec![], params=None))]
    fn new(
        gate_type: String,
        targets: Vec<usize>,
        controls: Vec<usize>,
        params: Option<Vec<f64>>,
    ) -> Self {
        Self {
            gate_type,
            targets,
            controls,
            params,
        }
    }

    fn __repr__(&self) -> String {
        format!(
            "<GateDesc type={} targets={:?} controls={:?}>",
            self.gate_type, self.targets, self.controls
        )
    }
}

/// Convert a PyGateDesc to a native Gate.
#[cfg(feature = "python")]
fn py_gate_desc_to_gate(desc: &PyGateDesc) -> PyResult<Gate> {
    let target = desc.targets.first().copied().unwrap_or(0);
    let control = desc.controls.first().copied().unwrap_or(0);
    let param = desc.params.as_ref().and_then(|p| p.first().copied()).unwrap_or(0.0);

    let gate = match desc.gate_type.to_lowercase().as_str() {
        "h" => Gate::h(target),
        "x" => Gate::x(target),
        "y" => Gate::y(target),
        "z" => Gate::z(target),
        "s" => Gate::s(target),
        "t" => Gate::t(target),
        "rx" => Gate::rx(target, param),
        "ry" => Gate::ry(target, param),
        "rz" => Gate::rz(target, param),
        "cnot" | "cx" => Gate::cnot(control, target),
        "cz" => {
            use crate::gates::GateType;
            Gate::new(GateType::CZ, vec![target], vec![control])
        }
        "swap" => {
            use crate::gates::GateType;
            let t2 = desc.targets.get(1).copied().unwrap_or(target);
            Gate::new(GateType::SWAP, vec![target, t2], vec![])
        }
        other => {
            return Err(PyValueError::new_err(format!(
                "Unknown gate type: '{}'. Supported: h, x, y, z, s, t, rx, ry, rz, cnot/cx, cz, swap",
                other
            )));
        }
    };
    Ok(gate)
}

/// Convert a native Gate back to PyGateDesc.
#[cfg(feature = "python")]
fn gate_to_py_gate_desc(gate: &Gate) -> PyGateDesc {
    use crate::gates::GateType;
    let (name, params) = match &gate.gate_type {
        GateType::H => ("h".to_string(), None),
        GateType::X => ("x".to_string(), None),
        GateType::Y => ("y".to_string(), None),
        GateType::Z => ("z".to_string(), None),
        GateType::S => ("s".to_string(), None),
        GateType::T => ("t".to_string(), None),
        GateType::Rx(a) => ("rx".to_string(), Some(vec![*a])),
        GateType::Ry(a) => ("ry".to_string(), Some(vec![*a])),
        GateType::Rz(a) => ("rz".to_string(), Some(vec![*a])),
        GateType::CNOT => ("cnot".to_string(), None),
        GateType::CZ => ("cz".to_string(), None),
        GateType::SWAP => ("swap".to_string(), None),
        GateType::Toffoli => ("toffoli".to_string(), None),
        GateType::CRx(a) => ("crx".to_string(), Some(vec![*a])),
        GateType::CRy(a) => ("cry".to_string(), Some(vec![*a])),
        GateType::CRz(a) => ("crz".to_string(), Some(vec![*a])),
        GateType::CR(a) => ("cr".to_string(), Some(vec![*a])),
        GateType::U { theta, phi, lambda } => {
            ("u".to_string(), Some(vec![*theta, *phi, *lambda]))
        }
        _ => ("unknown".to_string(), None),
    };
    PyGateDesc {
        gate_type: name,
        targets: gate.targets.clone(),
        controls: gate.controls.clone(),
        params,
    }
}

/// Optimization statistics returned from the circuit optimizer.
#[cfg(feature = "python")]
#[pyclass(name = "OptimizationStats")]
#[derive(Clone)]
pub struct PyOptStats {
    #[pyo3(get)]
    pub original_gates: usize,
    #[pyo3(get)]
    pub optimized_gates: usize,
    #[pyo3(get)]
    pub gates_removed: usize,
    #[pyo3(get)]
    pub fusions: usize,
    #[pyo3(get)]
    pub commutations: usize,
    #[pyo3(get)]
    pub cancellations: usize,
}

#[cfg(feature = "python")]
#[pymethods]
impl PyOptStats {
    /// Calculate gate reduction percentage.
    fn reduction_percentage(&self) -> f64 {
        if self.original_gates == 0 {
            return 0.0;
        }
        (self.gates_removed as f64 / self.original_gates as f64) * 100.0
    }

    fn __repr__(&self) -> String {
        format!(
            "<OptimizationStats original={} optimized={} removed={} ({:.1}%)>",
            self.original_gates,
            self.optimized_gates,
            self.gates_removed,
            self.reduction_percentage()
        )
    }
}

/// Python wrapper for CircuitOptimizer.
///
/// Provides multiple optimization passes: gate cancellation, fusion,
/// rotation merging, commutation analysis, and peephole optimization.
#[cfg(feature = "python")]
#[pyclass(name = "CircuitOptimizer")]
pub struct PyCircuitOptimizer {
    inner: crate::circuit_optimizer::CircuitOptimizer,
}

#[cfg(feature = "python")]
#[pymethods]
impl PyCircuitOptimizer {
    /// Create a new circuit optimizer.
    ///
    /// Args:
    ///     level: Optimization level ("none", "basic", "moderate", "aggressive")
    #[new]
    #[pyo3(signature = (level = "moderate"))]
    fn new(level: &str) -> PyResult<Self> {
        use crate::circuit_optimizer::OptimizationLevel;
        let level = match level {
            "none" => OptimizationLevel::None,
            "basic" => OptimizationLevel::Basic,
            "moderate" => OptimizationLevel::Moderate,
            "aggressive" => OptimizationLevel::Aggressive,
            _ => {
                return Err(PyValueError::new_err(
                    "level must be one of: none, basic, moderate, aggressive",
                ));
            }
        };
        Ok(Self {
            inner: crate::circuit_optimizer::CircuitOptimizer::new(level),
        })
    }

    /// Optimize a list of gate descriptions.
    ///
    /// Args:
    ///     gates: List of GateDesc objects representing the circuit
    ///
    /// Returns:
    ///     Tuple of (optimized_gates, stats) where optimized_gates is a list
    ///     of GateDesc and stats contains optimization statistics.
    fn optimize(&self, gates: Vec<PyGateDesc>) -> PyResult<(Vec<PyGateDesc>, PyOptStats)> {
        // Convert Python gate descriptions to native Gates
        let native_gates: Vec<Gate> = gates
            .iter()
            .map(py_gate_desc_to_gate)
            .collect::<PyResult<Vec<Gate>>>()?;

        // Run optimizer with stats
        let (optimized, stats) = self.inner.optimize_with_stats(&native_gates);

        // Convert back to Python gate descriptions
        let py_gates: Vec<PyGateDesc> = optimized.iter().map(gate_to_py_gate_desc).collect();

        let py_stats = PyOptStats {
            original_gates: stats.original_gates,
            optimized_gates: stats.optimized_gates,
            gates_removed: stats.gates_removed,
            fusions: stats.fusions,
            commutations: stats.commutations,
            cancellations: stats.cancellations,
        };

        Ok((py_gates, py_stats))
    }

    fn __repr__(&self) -> String {
        "<CircuitOptimizer>".to_string()
    }
}

// =============================================================================
// SURFACE CODE DECODER PYTHON BINDINGS
// =============================================================================

/// Python wrapper for surface code decoders (MWPM and BP).
///
/// Provides syndrome decoding for surface code quantum error correction.
#[cfg(feature = "python")]
#[pyclass(name = "SurfaceCodeDecoder")]
pub struct PySurfaceCodeDecoder {
    decoder_type: String,
    distance: usize,
}

#[cfg(feature = "python")]
#[pymethods]
impl PySurfaceCodeDecoder {
    /// Create a new surface code decoder.
    ///
    /// Args:
    ///     distance: Code distance (odd integer >= 3)
    ///     decoder_type: Decoder algorithm ("mwpm" or "bp")
    #[new]
    #[pyo3(signature = (distance, decoder_type = "mwpm"))]
    fn new(distance: usize, decoder_type: &str) -> PyResult<Self> {
        if distance < 3 || distance % 2 == 0 {
            return Err(PyValueError::new_err(
                "distance must be an odd integer >= 3",
            ));
        }
        match decoder_type {
            "mwpm" | "bp" => {}
            _ => {
                return Err(PyValueError::new_err(
                    "decoder_type must be 'mwpm' or 'bp'",
                ));
            }
        }
        Ok(Self {
            decoder_type: decoder_type.to_string(),
            distance,
        })
    }

    /// Decode a syndrome and return corrections.
    ///
    /// Args:
    ///     syndrome: List of boolean syndrome bits from stabilizer measurements
    ///
    /// Returns:
    ///     List of (qubit_index, correction_type) tuples where correction_type
    ///     is "X", "Z", or "I" (identity / no correction).
    fn decode(&self, syndrome: Vec<bool>) -> PyResult<Vec<(usize, String)>> {
        match self.decoder_type.as_str() {
            "mwpm" => {
                let num_qubits = self.distance * self.distance;
                let mut decoder = crate::decoding::MWPMDecoder::new(self.distance, num_qubits);
                let syn = crate::decoding::Syndrome::new(syndrome);
                let corrections = decoder.decode(&syn);
                let result: Vec<(usize, String)> = corrections
                    .iter()
                    .enumerate()
                    .map(|(i, &corrected)| {
                        let label = if corrected { "X" } else { "I" };
                        (i, label.to_string())
                    })
                    .collect();
                Ok(result)
            }
            "bp" => {
                use crate::decoding::bp::{BPConfig, BPDecoder, TannerGraph};
                let graph = TannerGraph::surface_code(self.distance);
                let decoder = BPDecoder::new(graph, BPConfig::default());
                let bp_result = decoder.decode(&syndrome, 0.01);
                let result: Vec<(usize, String)> = bp_result
                    .error_pattern
                    .iter()
                    .enumerate()
                    .map(|(i, &has_error)| {
                        let label = if has_error { "X" } else { "I" };
                        (i, label.to_string())
                    })
                    .collect();
                Ok(result)
            }
            _ => Err(PyValueError::new_err("Unknown decoder type")),
        }
    }

    /// Get the decoder algorithm type.
    fn decoder_type(&self) -> &str {
        &self.decoder_type
    }

    /// Get the code distance.
    fn distance(&self) -> usize {
        self.distance
    }

    fn __repr__(&self) -> String {
        format!(
            "<SurfaceCodeDecoder distance={} type={}>",
            self.distance, self.decoder_type
        )
    }
}

// =============================================================================
// PYTORCH BRIDGE PYTHON BINDINGS
// =============================================================================

use crate::pytorch_bridge::{
    DifferentiableCircuit, ParametricGate, Observable, GradientMethod,
    ForwardResult, BackwardResult,
};

/// Python wrapper for DifferentiableCircuit
#[cfg(feature = "python")]
#[pyclass(name = "DifferentiableCircuit")]
pub struct PyDifferentiableCircuit {
    inner: DifferentiableCircuit,
}

#[cfg(feature = "python")]
#[pymethods]
impl PyDifferentiableCircuit {
    /// Create a new differentiable quantum circuit.
    ///
    /// Args:
    ///     n_qubits: Number of qubits
    ///     gradient_method: Gradient computation method ('parameter_shift', 'adjoint', 'finite_diff', 'backprop')
    #[new]
    #[pyo3(signature = (n_qubits, gradient_method="adjoint"))]
    fn new(n_qubits: usize, gradient_method: &str) -> PyResult<Self> {
        let method = match gradient_method {
            "parameter_shift" => GradientMethod::ParameterShift { shift: std::f64::consts::FRAC_PI_2 },
            "adjoint" => GradientMethod::AdjointDiff,
            "finite_diff" => GradientMethod::FiniteDiff { epsilon: 1e-7 },
            "backprop" => GradientMethod::Backprop,
            _ => return Err(PyValueError::new_err(format!("Unknown gradient method: {}", gradient_method))),
        };

        let mut circuit = DifferentiableCircuit::new(n_qubits);
        circuit.gradient_method = method;
        Ok(Self { inner: circuit })
    }

    /// Add a parameter to the circuit.
    ///
    /// Args:
    ///     initial_value: Initial parameter value
    ///
    /// Returns:
    ///     Parameter index for use in parametric gates
    fn add_parameter(&mut self, initial_value: f64) -> usize {
        self.inner.add_parameter(initial_value)
    }

    /// Add a gate to the circuit.
    ///
    /// Args:
    ///     gate_type: Gate type string ('H', 'X', 'CX', 'RY', etc.)
    ///     qubits: Qubit index or tuple of indices for multi-qubit gates
    ///     param_idx: Optional parameter index for parametric gates
    fn add_gate(&mut self, gate_type: &str, qubits: &Bound<'_, pyo3::types::PyAny>, param_idx: Option<usize>) -> PyResult<()> {
        let gate = if let Ok(qubit) = qubits.extract::<usize>() {
            // Single-qubit gate
            match gate_type {
                "H" => ParametricGate::H(qubit),
                "X" => ParametricGate::X(qubit),
                "Z" => ParametricGate::Z(qubit),
                "RX" => {
                    let idx = param_idx.ok_or_else(|| PyValueError::new_err("RX requires param_idx"))?;
                    ParametricGate::Rx(qubit, idx)
                }
                "RY" => {
                    let idx = param_idx.ok_or_else(|| PyValueError::new_err("RY requires param_idx"))?;
                    ParametricGate::Ry(qubit, idx)
                }
                "RZ" => {
                    let idx = param_idx.ok_or_else(|| PyValueError::new_err("RZ requires param_idx"))?;
                    ParametricGate::Rz(qubit, idx)
                }
                _ => return Err(PyValueError::new_err(format!("Unknown single-qubit gate: {}", gate_type))),
            }
        } else if let Ok((control, target)) = qubits.extract::<(usize, usize)>() {
            // Two-qubit gate
            match gate_type {
                "CX" | "CNOT" => ParametricGate::CX(control, target),
                "CZ" => ParametricGate::CZ(control, target),
                _ => return Err(PyValueError::new_err(format!("Unknown two-qubit gate: {}", gate_type))),
            }
        } else {
            return Err(PyValueError::new_err("qubits must be int or tuple of ints"));
        };

        self.inner.add_gate(gate);
        Ok(())
    }

    /// Execute circuit and measure observables (forward pass).
    ///
    /// Args:
    ///     observables: List of (obs_type, qubits) tuples
    ///
    /// Returns:
    ///     Dictionary with expectation_values, state_vector (optional)
    fn forward(&self, py: Python<'_>, observables: Vec<(String, pyo3::Py<pyo3::types::PyAny>)>) -> PyResult<pyo3::Py<pyo3::types::PyDict>> {
        let obs_list: Result<Vec<Observable>, PyErr> = observables.iter().map(|(obs_type, qubits_py)| {
            let qubits_bound = qubits_py.bind(py);

            if let Ok(qubit) = qubits_bound.extract::<usize>() {
                match obs_type.as_str() {
                    "pauli_z" => Ok(Observable::PauliZ(qubit)),
                    "pauli_x" => Ok(Observable::PauliX(qubit)),
                    "pauli_y" => Ok(Observable::PauliY(qubit)),
                    _ => Err(PyValueError::new_err(format!("Unknown observable: {}", obs_type))),
                }
            } else if let Ok(pauli_string) = qubits_bound.extract::<Vec<(usize, String)>>() {
                let terms: Vec<(usize, char)> = pauli_string.iter().map(|(q, s)| {
                    (*q, s.chars().next().unwrap_or('I'))
                }).collect();
                Ok(Observable::PauliString(terms))
            } else {
                Err(PyValueError::new_err("Invalid observable specification"))
            }
        }).collect();

        let obs_list = obs_list?;

        let result = self.inner.forward(&obs_list)
            .map_err(|e| PyValueError::new_err(format!("Forward pass failed: {}", e)))?;

        let dict = pyo3::types::PyDict::new(py);
        dict.set_item("expectation_values", result.expectation_values.to_vec())?;

        if let Some(state) = result.state_vector {
            let state_list: Vec<(f64, f64)> = state.into_iter().collect();
            dict.set_item("state_vector", state_list)?;
        }

        Ok(dict.into())
    }

    /// Compute gradients (backward pass).
    ///
    /// Args:
    ///     observables: List of (obs_type, qubits) tuples
    ///
    /// Returns:
    ///     Dictionary with parameter_gradients [n_observables][n_params]
    fn backward(&self, py: Python<'_>, observables: Vec<(String, pyo3::Py<pyo3::types::PyAny>)>) -> PyResult<pyo3::Py<pyo3::types::PyDict>> {
        let obs_list: Result<Vec<Observable>, PyErr> = observables.iter().map(|(obs_type, qubits_py)| {
            let qubits_bound = qubits_py.bind(py);

            if let Ok(qubit) = qubits_bound.extract::<usize>() {
                match obs_type.as_str() {
                    "pauli_z" => Ok(Observable::PauliZ(qubit)),
                    "pauli_x" => Ok(Observable::PauliX(qubit)),
                    "pauli_y" => Ok(Observable::PauliY(qubit)),
                    _ => Err(PyValueError::new_err(format!("Unknown observable: {}", obs_type))),
                }
            } else {
                Err(PyValueError::new_err("Invalid observable specification"))
            }
        }).collect();

        let obs_list = obs_list?;

        let result = self.inner.backward(&obs_list)
            .map_err(|e| PyValueError::new_err(format!("Backward pass failed: {}", e)))?;

        let dict = pyo3::types::PyDict::new(py);
        dict.set_item("parameter_gradients", result.parameter_gradients)?;
        dict.set_item("gradient_method", result.gradient_method_used)?;
        Ok(dict.into())
    }

    fn __repr__(&self) -> String {
        format!(
            "<DifferentiableCircuit n_qubits={} n_params={} n_gates={}>",
            self.inner.num_qubits,
            self.inner.parameters.len(),
            self.inner.gates.len()
        )
    }
}

/// Standalone forward pass function for PyTorch integration.
///
/// Args:
///     params: List of parameter values
///     n_qubits: Number of qubits
///     gates: List of (gate_type, qubits, param_idx) tuples
///     observables: List of (obs_type, qubits) tuples
///
/// Returns:
///     Dictionary with expectation_values and optional state_vector
#[cfg(feature = "python")]
#[pyfunction]
fn pytorch_forward(
    py: Python<'_>,
    params: Vec<f64>,
    n_qubits: usize,
    gates: Vec<(String, pyo3::Py<pyo3::types::PyAny>, Option<usize>)>,
    observables: Vec<(String, pyo3::Py<pyo3::types::PyAny>)>,
) -> PyResult<pyo3::Py<pyo3::types::PyDict>> {
    // Build circuit
    let mut circuit = DifferentiableCircuit::new(n_qubits);

    // Add parameters
    for &param_val in &params {
        circuit.add_parameter(param_val);
    }

    // Add gates
    for (gate_type, qubits_py, param_idx) in gates {
        let qubits_bound = qubits_py.bind(py);

            let gate = if let Ok(qubit) = qubits_bound.extract::<usize>() {
                match gate_type.as_str() {
                    "H" => ParametricGate::H(qubit),
                    "X" => ParametricGate::X(qubit),
                    "Z" => ParametricGate::Z(qubit),
                    "RX" => ParametricGate::Rx(qubit, param_idx.ok_or_else(|| PyValueError::new_err("RX requires param_idx"))?),
                    "RY" => ParametricGate::Ry(qubit, param_idx.ok_or_else(|| PyValueError::new_err("RY requires param_idx"))?),
                    "RZ" => ParametricGate::Rz(qubit, param_idx.ok_or_else(|| PyValueError::new_err("RZ requires param_idx"))?),
                    _ => return Err(PyValueError::new_err(format!("Unknown gate: {}", gate_type))),
                }
            } else if let Ok((control, target)) = qubits_bound.extract::<(usize, usize)>() {
                match gate_type.as_str() {
                    "CX" => ParametricGate::CX(control, target),
                    "CZ" => ParametricGate::CZ(control, target),
                    _ => return Err(PyValueError::new_err(format!("Unknown two-qubit gate: {}", gate_type))),
                }
            } else {
                return Err(PyValueError::new_err("Invalid qubit specification"));
            };

            circuit.add_gate(gate);
            Ok::<(), PyErr>(())
        }?;
    }

    // Parse observables
    let obs_list: Result<Vec<Observable>, PyErr> = observables.iter().map(|(obs_type, qubits_py)| {
        let qubits_bound = qubits_py.bind(py);

        if let Ok(qubit) = qubits_bound.extract::<usize>() {
            match obs_type.as_str() {
                "pauli_z" => Ok(Observable::PauliZ(qubit)),
                "pauli_x" => Ok(Observable::PauliX(qubit)),
                "pauli_y" => Ok(Observable::PauliY(qubit)),
                _ => Err(PyValueError::new_err(format!("Unknown observable: {}", obs_type))),
            }
        } else {
            Err(PyValueError::new_err("Invalid observable"))
        }
    }).collect();

    let obs_list = obs_list?;

    // Execute forward pass
    let result = circuit.forward(&obs_list)
        .map_err(|e| PyValueError::new_err(format!("Forward failed: {}", e)))?;

    let dict = pyo3::types::PyDict::new(py);
    dict.set_item("expectation_values", result.expectation_values.to_vec())?;

    if let Some(state) = result.state_vector {
        let state_list: Vec<(f64, f64)> = state.into_iter().collect();
        dict.set_item("state_vector", state_list)?;
    }

    Ok(dict.into())
}

/// Standalone backward pass function for PyTorch integration.
///
/// Args:
///     params: List of parameter values
///     grad_output: Gradient from downstream (per observable)
///     n_qubits: Number of qubits
///     gates: List of (gate_type, qubits, param_idx) tuples
///     observables: List of (obs_type, qubits) tuples
///     method: Gradient method ('parameter_shift', 'adjoint', etc.)
///
/// Returns:
///     Dictionary with parameter_gradients
#[cfg(feature = "python")]
#[pyfunction]
fn pytorch_backward(
    params: Vec<f64>,
    grad_output: Vec<f64>,
    n_qubits: usize,
    gates: Vec<(String, pyo3::Py<pyo3::types::PyAny>, Option<usize>)>,
    observables: Vec<(String, pyo3::Py<pyo3::types::PyAny>)>,
    method: String,
) -> PyResult<pyo3::Py<pyo3::types::PyDict>> {
    use pyo3::prelude::*;

    // Build circuit (same as forward)
    let grad_method = match method.as_str() {
        "parameter_shift" => GradientMethod::ParameterShift { shift: std::f64::consts::FRAC_PI_2 },
        "adjoint" => GradientMethod::AdjointDiff,
        "finite_diff" => GradientMethod::FiniteDiff { epsilon: 1e-7 },
        "backprop" => GradientMethod::Backprop,
        _ => return Err(PyValueError::new_err(format!("Unknown gradient method: {}", method))),
    };

    let mut circuit = DifferentiableCircuit::new(n_qubits);
    circuit.gradient_method = grad_method;

    for &param_val in &params {
        circuit.add_parameter(param_val);
    }

    for (gate_type, qubits_py, param_idx) in gates {
        Python::with_gil(|py| {
            let qubits_bound = qubits_py.bind(py);

            let gate = if let Ok(qubit) = qubits_bound.extract::<usize>() {
                match gate_type.as_str() {
                    "H" => ParametricGate::H(qubit),
                    "X" => ParametricGate::X(qubit),
                    "Z" => ParametricGate::Z(qubit),
                    "RX" => ParametricGate::Rx(qubit, param_idx.ok_or_else(|| PyValueError::new_err("RX needs param_idx"))?),
                    "RY" => ParametricGate::Ry(qubit, param_idx.ok_or_else(|| PyValueError::new_err("RY needs param_idx"))?),
                    "RZ" => ParametricGate::Rz(qubit, param_idx.ok_or_else(|| PyValueError::new_err("RZ needs param_idx"))?),
                    _ => return Err(PyValueError::new_err(format!("Unknown gate: {}", gate_type))),
                }
            } else if let Ok((c, t)) = qubits_bound.extract::<(usize, usize)>() {
                match gate_type.as_str() {
                    "CX" => ParametricGate::CX(c, t),
                    "CZ" => ParametricGate::CZ(c, t),
                    _ => return Err(PyValueError::new_err(format!("Unknown two-qubit gate: {}", gate_type))),
                }
            } else {
                return Err(PyValueError::new_err("Invalid qubits"));
            };

            circuit.add_gate(gate);
            Ok::<(), PyErr>(())
        })?;
    }

    // Parse observables
    let obs_list: Result<Vec<Observable>, PyErr> = observables.iter().map(|(obs_type, qubits_py)| {
        Python::with_gil(|py| {
            let qubits_bound = qubits_py.bind(py);

            if let Ok(qubit) = qubits_bound.extract::<usize>() {
                match obs_type.as_str() {
                    "pauli_z" => Ok(Observable::PauliZ(qubit)),
                    "pauli_x" => Ok(Observable::PauliX(qubit)),
                    "pauli_y" => Ok(Observable::PauliY(qubit)),
                    _ => Err(PyValueError::new_err(format!("Unknown observable: {}", obs_type))),
                }
            } else {
                Err(PyValueError::new_err("Invalid observable"))
            }
        })
    }).collect();

    let obs_list = obs_list?;

    // Compute gradients
    let result = circuit.backward(&obs_list)
        .map_err(|e| PyValueError::new_err(format!("Backward failed: {}", e)))?;

    // Chain rule: grad_params = grad_output @ jacobian
    // jacobian[i][j] = d(expectation_i)/d(param_j)
    let n_params = params.len();
    let mut final_grads = vec![0.0; n_params];

    for (obs_idx, obs_grads) in result.parameter_gradients.iter().enumerate() {
        let grad_scale = grad_output.get(obs_idx).copied().unwrap_or(1.0);
        for (param_idx, &grad_val) in obs_grads.iter().enumerate() {
            final_grads[param_idx] += grad_scale * grad_val;
        }
    }

    Python::with_gil(|py| {
        let dict = pyo3::types::PyDict::new(py);
        dict.set_item("parameter_gradients", final_grads)?;
        dict.set_item("gradient_method", result.gradient_method_used)?;
        Ok(dict.into())
    })
}

/// Compute gradients without grad_output (for direct gradient access).
#[cfg(feature = "python")]
#[pyfunction]
fn pytorch_gradient(
    params: Vec<f64>,
    n_qubits: usize,
    gates: Vec<(String, pyo3::Py<pyo3::types::PyAny>, Option<usize>)>,
    observables: Vec<(String, pyo3::Py<pyo3::types::PyAny>)>,
    method: String,
) -> PyResult<pyo3::Py<pyo3::types::PyDict>> {
    // Reuse backward with grad_output = [1.0, 1.0, ...]
    let grad_output = vec![1.0; observables.len()];
    pytorch_backward(params, grad_output, n_qubits, gates, observables, method)
}

/// Get state vector after executing circuit.
#[cfg(feature = "python")]
#[pyfunction]
fn pytorch_get_state(
    params: Vec<f64>,
    n_qubits: usize,
    gates: Vec<(String, pyo3::Py<pyo3::types::PyAny>, Option<usize>)>,
) -> PyResult<Vec<(f64, f64)>> {
    use pyo3::prelude::*;

    let mut circuit = DifferentiableCircuit::new(n_qubits);

    for &param_val in &params {
        circuit.add_parameter(param_val);
    }

    for (gate_type, qubits_py, param_idx) in gates {
        Python::with_gil(|py| {
            let qubits_bound = qubits_py.bind(py);

            let gate = if let Ok(qubit) = qubits_bound.extract::<usize>() {
                match gate_type.as_str() {
                    "H" => ParametricGate::H(qubit),
                    "X" => ParametricGate::X(qubit),
                    "Z" => ParametricGate::Z(qubit),
                    "RX" => ParametricGate::Rx(qubit, param_idx.ok_or_else(|| PyValueError::new_err("RX needs param_idx"))?),
                    "RY" => ParametricGate::Ry(qubit, param_idx.ok_or_else(|| PyValueError::new_err("RY needs param_idx"))?),
                    "RZ" => ParametricGate::Rz(qubit, param_idx.ok_or_else(|| PyValueError::new_err("RZ needs param_idx"))?),
                    _ => return Err(PyValueError::new_err(format!("Unknown gate: {}", gate_type))),
                }
            } else if let Ok((c, t)) = qubits_bound.extract::<(usize, usize)>() {
                match gate_type.as_str() {
                    "CX" => ParametricGate::CX(c, t),
                    "CZ" => ParametricGate::CZ(c, t),
                    _ => return Err(PyValueError::new_err(format!("Unknown gate: {}", gate_type))),
                }
            } else {
                return Err(PyValueError::new_err("Invalid qubits"));
            };

            circuit.add_gate(gate);
            Ok::<(), PyErr>(())
        })?;
    }

    // Dummy observable (not used, we just want state)
    let obs = vec![Observable::PauliZ(0)];
    let result = circuit.forward(&obs)
        .map_err(|e| PyValueError::new_err(format!("State computation failed: {}", e)))?;

    if let Some(state) = result.state_vector {
        Ok(state.into_iter().collect())
    } else {
        Err(PyValueError::new_err("State vector not available"))
    }
}
